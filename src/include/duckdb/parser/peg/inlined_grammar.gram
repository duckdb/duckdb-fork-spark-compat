SecretStorageSpecifier <- 'IN' Identifier
SecretName <- ColId

CreateSequenceStmt <- 'SEQUENCE' IfNotExists? QualifiedName SequenceOption*

SequenceOption <-
	SeqSetCycle /
	SeqSetIncrement /
	SeqSetMinMax /
	SeqNoMinMax /
	SeqStartWith /
	SeqOwnedBy

SeqSetCycle <- SeqCycle / SeqNoCycle
SeqCycle <- 'CYCLE'
SeqNoCycle <- 'NO' 'CYCLE'
