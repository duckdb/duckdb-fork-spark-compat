ConstraintNameClause <- 'CONSTRAINT' Identifier
TopCheckConstraint <- CheckConstraint
TopPrimaryKeyConstraint <- 'PRIMARY' 'KEY' ColumnIdList
TopUniqueConstraint <- 'UNIQUE' ColumnIdList
TopForeignKeyConstraint <- 'FOREIGN' 'KEY' ColumnIdList ForeignKeyConstraint
ColumnIdList <- Parens(List(ColId))

PlainIdentifier <- !ReservedKeyword <[a-z_]i[a-z0-9_]i*>
QuotedIdentifier <- '"' [^"]* '"'
DottedIdentifier <- Identifier DotColLabel*
DotColLabel <- '.' ColLabel
Identifier <- QuotedIdentifier / PlainIdentifier

ColId <- UnreservedKeyword / ColumnNameKeyword / Identifier
ColIdOrString <- ColId / StringLiteralIdentifier
TypeFuncName <- UnreservedKeyword / TypeNameKeyword / FuncNameKeyword / Identifier
TypeName <- UnreservedKeyword / TypeNameKeyword / Identifier
ColLabel <- ReservedKeyword / UnreservedKeyword / ColumnNameKeyword / FuncNameKeyword / TypeNameKeyword / Identifier
ColLabelOrString <- ColLabelIdentifier / StringLiteralIdentifier
ColLabelIdentifier <- ColLabel
StringLiteralIdentifier <- StringLiteral
GeneratedColumn <- Generated? 'AS' Parens(Expression) GeneratedColumnType?

Generated <- 'GENERATED' AlwaysOrByDefault?
AlwaysOrByDefault <- 'ALWAYS' / ('BY' 'DEFAULT')
GeneratedColumnType <- VirtualGeneratedColumn / StoredGeneratedColumn

CommitAction <- 'ON' 'COMMIT' PreserveOrDelete 'ROWS'
PreserveOrDelete <- PreserveRows / DeleteRows
PreserveRows <- 'PRESERVE'
DeleteRows <- 'DELETE'
VirtualGeneratedColumn <- 'VIRTUAL'
StoredGeneratedColumn <- 'STORED'

CreateTriggerStmt <- 'TRIGGER' IfNotExists? TriggerName TriggerTiming TriggerEvent 'ON' BaseTableName ReferencingClause? ForEachClause? TriggerBody

TriggerBody <- InsertStatement / UpdateStatement / DeleteStatement / MergeIntoStatement
TriggerName <- Identifier

ReferencingClause <- 'REFERENCING' ReferencingItem ReferencingItem?
ReferencingItem <- ReferencingNewTableAs / ReferencingOldTableAs
ReferencingNewTableAs <- 'NEW' 'TABLE' 'AS' ColId
ReferencingOldTableAs <- 'OLD' 'TABLE' 'AS' ColId

TriggerTiming <- TriggerBefore / TriggerAfter / TriggerInsteadOf
TriggerBefore <- 'BEFORE'
TriggerAfter <- 'AFTER'
TriggerInsteadOf <- 'INSTEAD' 'OF'

TriggerEvent <- TriggerEventUpdateOf / TriggerEventInsert / TriggerEventDelete / TriggerEventUpdate
TriggerEventInsert <- 'INSERT'
TriggerEventDelete <- 'DELETE'
TriggerEventUpdate <- 'UPDATE'
TriggerEventUpdateOf <- 'UPDATE' 'OF' TriggerColumnList

TriggerColumnList <- List(ColId)

ForEachClause <- ForEachRow / ForEachStatement
ForEachRow <- 'FOR' 'EACH' 'ROW'
ForEachStatement <- 'FOR' 'EACH' 'STATEMENT'

CreateTypeStmt <- 'TYPE' IfNotExists? QualifiedName 'AS' CreateType
CreateType <- EnumSelectType / EnumStringLiteralList / CreateTypeFromType
CreateTypeFromType <- Type
EnumSelectType <- 'ENUM' Parens(SelectStatementInternal)
EnumStringLiteralList <- 'ENUM' Parens(List(StringLiteral)?)

CreateViewStmt <- CreateRecursive? 'VIEW' IfNotExists? QualifiedName ViewColumnList? WithSchemaMode? InsertColumnList? WithList? 'AS' SelectStatementInternal
CreateRecursive <- 'RECURSIVE'
