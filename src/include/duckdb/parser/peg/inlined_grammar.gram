AlterStatement <- 'ALTER' AlterOptions

AlterOptions <- AlterTableStmt / AlterViewStmt / AlterSequenceStmt / AlterDatabaseStmt / AlterSchemaStmt

AlterTableStmt <- 'TABLE' IfExists? BaseTableName List(AlterTableOptions)
AlterSchemaStmt <- 'SCHEMA' IfExists? QualifiedName RenameAlter

# Spark's ALTER TABLE ... SET/UNSET TBLPROPERTIES. Only the reserved 'comment' property maps onto a duckdb
# concept (the table comment); every other property is accepted and dropped. Lives at the Statement level
# because it yields either an AlterStatement or, with no 'comment' property, a no-op VacuumStatement.
SparkAlterTblPropertiesStmt <- 'ALTER' 'TABLE' BaseTableName SparkTblPropertiesAction
SparkTblPropertiesAction <- SparkSetTblProperties / SparkUnsetTblProperties
SparkSetTblProperties <- 'SET' 'TBLPROPERTIES' Parens(List(SparkTblProperty))
SparkUnsetTblProperties <- 'UNSET' 'TBLPROPERTIES' IfExists? Parens(List(ColIdOrString))
SparkTblProperty <- ColIdOrString SparkTblPropertyValue?
SparkTblPropertyValue <- '='? ColIdOrString

AlterTableOptions <- AddColumn / DropColumn / AlterColumn / AddConstraint / ChangeNullability /
        RenameColumn / RenameAlter / SetPartitionedBy / ResetPartitionedBy / SetSortedBy / ResetSortedBy / SetOptions / ResetOptions

AddConstraint <- 'ADD' TopLevelConstraint
AddColumn <- 'ADD' 'COLUMN'? IfNotExists? AddColumnEntry
AddColumnEntry <- DottedIdentifier Type? GeneratedColumn? ColumnConstraint*
DropColumn <- 'DROP' 'COLUMN'? IfExists? NestedColumnName DropBehavior?
AlterColumn <- 'ALTER' 'COLUMN'? NestedColumnName AlterColumnEntry
RenameColumn <- 'RENAME' 'COLUMN'? NestedColumnName 'TO' Identifier
NestedColumnName <- IdentifierDot* ColumnName
IdentifierDot <- Identifier '.'
RenameAlter <- 'RENAME' 'TO' Identifier
SetPartitionedBy <- 'SET' 'PARTITIONED' 'BY' Parens(List(Expression))
ResetPartitionedBy <- 'RESET' 'PARTITIONED' 'BY'
SetSortedBy <- 'SET' 'SORTED' 'BY' Parens(OrderByExpressions)
ResetSortedBy <- 'RESET' 'SORTED' 'BY'
SetOptions <- 'SET' RelOptionList
ResetOptions <- 'RESET' RelOptionList

AlterColumnEntry <- AddOrDropDefault / ChangeNullability / AlterType

AddOrDropDefault <- AddDefault / DropDefault
AddDefault <- 'SET' 'DEFAULT' Expression
DropDefault <- 'DROP' 'DEFAULT'

ChangeNullability <- DropOrSet 'NOT' 'NULL'
DropOrSet <- DropNullability / SetNullability
DropNullability <- 'DROP'
SetNullability <- 'SET'

AlterType <- SetData? 'TYPE' Type? UsingExpression?
SetData <- 'SET' 'DATA'?
UsingExpression <- 'USING' Expression

AlterViewStmt <- 'VIEW' IfExists? BaseTableName RenameAlter

AlterSequenceStmt <- 'SEQUENCE' IfExists? QualifiedSequenceName AlterSequenceOptions

QualifiedSequenceName <- CatalogQualification? SchemaQualification? SequenceName

AlterSequenceOptions <- RenameAlterSequenceOptions / SetSequenceOption
RenameAlterSequenceOptions <- RenameAlter
SetSequenceOption <- SequenceOption+

AlterDatabaseStmt <- 'DATABASE' IfExists? Identifier 'SET' 'ALIAS' 'TO' Identifier

AnalyzeStatement <- 'ANALYZE' AnalyzeVerbose? 'TABLE'? AnalyzeTarget? PartitionSpec? AnalyzeComputeStatistics?
AnalyzeTarget <- BaseTableName NameList?
AnalyzeVerbose <- 'VERBOSE'
# Spark's COMPUTE STATISTICS tail. DuckDB has no partition/column statistics, so the whole clause is parsed
# and ignored (AnalyzeComputeStatistics / AnalyzeStatsScope are excluded_rules: matched but not transformed).
AnalyzeComputeStatistics <- 'COMPUTE' 'STATISTICS' AnalyzeStatsScope?
AnalyzeStatsScope <- 'NOSCAN' / ('FOR' 'ALL' 'COLUMNS') / ('FOR' 'COLUMNS' NameList)

AttachStatement <- 'ATTACH' OrReplace? IfNotExists? Database? DatabasePath AttachAlias? AttachOptions?

Database <- 'DATABASE'
DatabasePath <- Expression
AttachAlias <- 'AS' ColId
AttachOptions <- GenericCopyOptionList

CallStatement <- 'CALL' QualifiedTableFunction TableFunctionArguments

CheckpointStatement <- CheckpointForce? 'CHECKPOINT' CatalogName?
CheckpointForce <- 'FORCE'

CommentStatement <- 'COMMENT' 'ON' CommentOnType DottedIdentifier 'IS' CommentValue

CommentOnType <-    CommentTable / CommentSequence / CommentFunction / CommentMacroTable / CommentMacro /
                    CommentView / CommentDatabase / CommentIndex / CommentSchema / CommentType / CommentColumn

CommentTable <- 'TABLE'
CommentSequence <- 'SEQUENCE'
CommentFunction <- 'FUNCTION'
CommentMacroTable <- 'MACRO' 'TABLE'
CommentMacro <- 'MACRO'
CommentView <- 'VIEW'
CommentDatabase <- 'DATABASE'
CommentIndex <- 'INDEX'
CommentSchema <- 'SCHEMA'
CommentType <- 'TYPE'
CommentColumn <- 'COLUMN'

CommentValue <- NullLiteral / StringLiteralValue
StringLiteralValue <- StringLiteral

ConnectStatement <- 'CONNECT' SessionTarget?
DisconnectStatement <- 'DISCONNECT'
SessionTarget <- LocalSessionTarget / StringSessionTarget / CatalogSessionTarget
LocalSessionTarget <- 'LOCAL'
StringSessionTarget <- StringLiteral GenericCopyOptionList?
CatalogSessionTarget <- CatalogName

CopyStatement <- 'COPY' CopyVariations
CopyVariations <- CopyTable / CopySelect / CopyFromDatabase

CopyTable <- BaseTableName InsertColumnList? FromOrTo CopyFileName CopyOptions?
FromOrTo <- CopyFrom / CopyTo
CopyFrom <- 'FROM'
CopyTo <- 'TO'

CopySelect <- Parens(SelectStatementInternal) 'TO' CopyFileName CopyOptions?

CopyFileName <- CopyFileNameExpression / CopyFileNameStringLiteral / CopyFileNameIdentifier / CopyFileNameIdentifierColId
CopyFileNameExpression <- Parameter / ParensExpression
CopyFileNameStringLiteral <- StringLiteral
CopyFileNameIdentifier <- Identifier
CopyFileNameIdentifierColId <- IdentifierColId
IdentifierColId <- Identifier '.' ColId
CopyOptions <- 'WITH'? CopyOptionList
CopyOptionList <- GenericCopyOptionList / SpecializedOptionList
SpecializedOptionList <- SpecializedOption*
SpecializedOption <- SingleOption / NullAsOption / DelimiterAsOption / EscapeAsOption /
	EncodingOption / QuoteAsOption / ForceQuoteOption / PartitionByOption / ForceNullOption

SingleOption <- BinaryOption / FreezeOption / OidsOption / CsvOption / HeaderOption
BinaryOption <- 'BINARY'
FreezeOption <- 'FREEZE'
OidsOption <- 'OIDS'
CsvOption <- 'CSV'
HeaderOption <- 'HEADER'
NullAsOption <- 'NULL' 'AS'? StringLiteral
DelimiterAsOption <- 'DELIMITER' 'AS'? StringLiteral
QuoteAsOption <- 'QUOTE' 'AS'? StringLiteral
EscapeAsOption <- 'ESCAPE' 'AS'? StringLiteral
EncodingOption <- 'ENCODING' StringLiteral
ForceQuoteOption <- ForceQuote? 'QUOTE' StarSymbolColumnList
StarSymbolColumnList <- StarSymbol / ColumnList
ForceQuote <- 'FORCE'
PartitionByOption <- 'PARTITION' 'BY' StarSymbolColumnList
ForceNullOption <- 'FORCE' ForceNotNull? 'NULL' ColumnList
ForceNotNull <- 'NOT'
StarSymbol <- '*'

GenericCopyOptionList <- Parens(List(GenericCopyOption))
GenericCopyOption <- CopyOptionName GenericCopyOptionValue?
GenericCopyOptionValue <- GenericCopyOptionOrderList / GenericCopyOptionExpression
GenericCopyOptionOrderList <- GenericCopyOptionParenthesizedExpressionList
GenericCopyOptionExpression <- Expression
GenericCopyOptionParenthesizedExpressionList <- Parens(OrderByExpressionList)

CopyFromDatabase <- CopyFromDatabaseWithFlag / CopyFromDatabaseWithoutFlag
CopyFromDatabaseWithFlag <- 'FROM' 'DATABASE' ColId 'TO' ColId CopyDatabaseFlag
CopyFromDatabaseWithoutFlag <- 'FROM' 'DATABASE' ColId 'TO' ColId

CopyDatabaseFlag <- Parens(SchemaOrData)
SchemaOrData <- CopySchema / CopyData
CopySchema <- 'SCHEMA'
CopyData <- 'DATA'

CreateIndexStmt <- UniqueIndex? 'INDEX' IfNotExists? IndexName? 'ON' BaseTableName InsertColumnList? IndexType? Parens(List(IndexElement))? WithList? WhereClause?

WithList <- 'WITH' RelOptionOrOids
RelOptionOrOids <- RelOptionList / Oids
RelOptionList <- Parens(List(RelOption))
Oids <- WithOrWithoutOids 'OIDS'
WithOrWithoutOids <- WithOids / WithoutOids
WithOids <- 'WITH'
WithoutOids <- 'WITHOUT'
IndexElement <- Expression DescOrAsc? NullsFirstOrLast?
UniqueIndex <- 'UNIQUE'
IndexType <- 'USING' Identifier
RelOption <- RelOptionName RelOptionArgumentOpt?
RelOptionName <- DottedIdentifierString / StringLiteral
DottedIdentifierString <- DottedIdentifier
RelOptionArgumentOpt <- '=' DefArg
DefArg <- DefArgNull / DefArgStringLiteral / NumberLiteral / NoneLiteral / Expression / DefArgKeyword
DefArgNull <- NullLiteral
DefArgKeyword <- ReservedKeyword
DefArgStringLiteral <- StringLiteral
NoneLiteral <- 'NONE'

CreateMacroStmt <- MacroOrFunction IfNotExists? QualifiedName List(MacroDefinition)

MacroOrFunction <- MacroKeyword / FunctionKeyword
MacroKeyword <- 'MACRO'
FunctionKeyword <- 'FUNCTION'

MacroDefinition <- Parens(MacroParameters?) 'AS' MacroDefinitionBody
MacroDefinitionBody <- TableMacroDefinition / ScalarMacroDefinition

MacroParameters <- List(MacroParameter)
MacroParameter <- NamedParameter / SimpleParameter
SimpleParameter <- TypeFuncName Type?

ScalarMacroDefinition <- Expression
