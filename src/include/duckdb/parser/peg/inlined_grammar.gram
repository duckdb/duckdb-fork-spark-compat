Persistent <- 'PERSISTENT'
TempPersistent <- 'TEMP'
TemporaryPersistent <- 'TEMPORARY'

CreateTableStmt <- 'TABLE' IfNotExists? QualifiedName CreateTableDefinition CommitAction?
CreateTableDefinition <- CreateTableAs / CreateColumnList
SparkUsing <- 'USING' Identifier SparkLocation?
SparkLocation <- 'LOCATION' StringLiteral
# Spark's table-level COMMENT clause. ColIdOrString accepts both 'text' and spark's double-quoted "text".
SparkTableComment <- 'COMMENT' ColIdOrString
CreateTableAs <- SparkUsing? IdentifierList? PartitionSortedOptions? SparkTableComment? WithList? 'AS' Statement WithData?
PartitionSortedOptions <- PartitionOptSortedOptions / SortedOptPartitionOptions
PartitionOptSortedOptions <- PartitionOptions SortedOptions?
SortedOptPartitionOptions <- SortedOptions PartitionOptions?
PartitionOptions <- 'PARTITIONED' 'BY' Parens(List(PartitionField))
PartitionField <- Expression Type?
SortedOptions <- 'SORTED' 'BY' Parens(List(Expression))

WithData <- WithDataOnly / WithNoData
WithDataOnly <- 'WITH' 'DATA'
WithNoData <- 'WITH' 'NO' 'DATA'
IdentifierList <- Parens(List(Identifier))
CreateColumnList <- Parens(CreateTableColumnList?) SparkUsing? PartitionSortedOptions? SparkTableComment? WithList?
IfNotExists <- 'IF' 'NOT' 'EXISTS'
QualifiedName <- CatalogReservedSchemaIdentifier / SchemaReservedIdentifierOrStringLiteral / IdentifierOrStringLiteral
SchemaReservedIdentifierOrStringLiteral <- SchemaQualification ReservedIdentifierOrStringLiteral
CatalogReservedSchemaIdentifier <- CatalogQualification ReservedSchemaQualification ReservedIdentifierOrStringLiteral
IdentifierOrStringLiteral <- Identifier / StringLiteral
ReservedIdentifierOrStringLiteral <- ReservedIdentifier / StringLiteral
CatalogQualification <- CatalogName '.'
SchemaQualification <- SchemaName '.'
ReservedSchemaQualification <- ReservedSchemaName '.'
TableQualification <- TableName '.'
ReservedTableQualification <- ReservedTableName '.'

CreateTableColumnList <- List(CreateTableColumnElement)
CreateTableColumnElement <- CreateTableColumnDefinition / CreateTableConstraint
CreateTableColumnDefinition <- ColumnDefinition
CreateTableConstraint <- TopLevelConstraint
ColumnDefinition <- DottedIdentifier Type? GeneratedColumn? ConstraintNameClause? ColumnConstraint*
ColumnConstraint <- NotNullConstraint / UniqueConstraint / PrimaryKeyConstraint / DefaultValue / CheckConstraint / ForeignKeyConstraint / ColumnCollation / ColumnCompression / ColumnComment
ColumnComment <- 'COMMENT' StringLiteral
NotNullConstraint <- NullConstraint / NotNullColumnConstraint
NullConstraint <- 'NULL'
NotNullColumnConstraint <- 'NOT' 'NULL'
UniqueConstraint <- 'UNIQUE'
PrimaryKeyConstraint <- 'PRIMARY' 'KEY'
DefaultValue <- 'DEFAULT' ColumnDefaultExpr
CheckConstraint <- 'CHECK' Parens(Expression)
ForeignKeyConstraint <- 'REFERENCES' BaseTableName Parens(ColumnList)? KeyActions
ColumnCollation <- 'COLLATE' DottedIdentifier
ColumnCompression <- 'USING' 'COMPRESSION' ColIdOrString

KeyActions <- UpdateAction? DeleteAction?
UpdateAction <- 'ON' 'UPDATE' KeyAction
DeleteAction <- 'ON' 'DELETE' KeyAction
KeyAction <- NoKeyAction / RestrictKeyAction / CascadeKeyAction / SetNullKeyAction / SetDefaultKeyAction
NoKeyAction <- 'NO' 'ACTION'
RestrictKeyAction <- 'RESTRICT'
CascadeKeyAction <- 'CASCADE'
SetNullKeyAction <- 'SET' 'NULL'
SetDefaultKeyAction <- 'SET' 'DEFAULT'

TopLevelConstraint <- ConstraintNameClause? TopLevelConstraintList
