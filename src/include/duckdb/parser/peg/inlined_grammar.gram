Program <- TopLevelStatement*

TopLevelStatement <- Statement? (';'+ / EndOfInput)

Statement <-
	CreateStatement /
	SelectStatement /
	SetStatement /
	ReadSettingStatement /
	PragmaStatement /
	CallStatement /
	InsertStatement /
	DeclareStatement /
	DropVariableStatement /
	DropStatement /
	CopyStatement /
	ExplainStatement /
	UpdateStatement /
	PrepareStatement /
	ExecuteStatement /
	SparkAlterTblPropertiesStmt /
	AlterStatement /
	TransactionStatement /
	DeleteStatement /
	AttachStatement /
	UseStatement /
	DetachStatement /
	CheckpointStatement /
	VacuumStatement /
	ResetStatement /
	ExportStatement /
	ImportStatement /
	CommentStatement /
	DeallocateStatement /
	TruncateStatement /
	LoadStatement /
	InstallStatement /
	UpdateExtensionsStatement /
	AnalyzeStatement /
	MergeIntoStatement /
	ConnectStatement /
	DisconnectStatement /
	ExpressionStatement

ExpressionStatement <- List(ExpressionAlias)
ExpressionAlias <- ColIdExpression / ExpressionAsCollabel / Expression

CatalogName <- Identifier
SchemaName <- Identifier
ReservedSchemaName <- Identifier
TableName <- Identifier
ReservedTableName <- Identifier
ReservedIdentifier <- Identifier
ColumnName <- Identifier
ReservedColumnName <- Identifier
IndexName <- Identifier
ReservedIndexName <- Identifier
SettingName <- Identifier
PragmaName <- Identifier
FunctionName <- Identifier
ReservedFunctionName <- Identifier
ReservedTypeName <- Identifier
TableFunctionName <- Identifier
ConstraintName <- ColIdOrString
SequenceName <- Identifier
CollationName <- Identifier
CopyOptionName <- ColLabel

NumberLiteral <- < [+-]?[0-9]*([.][0-9]*)? >
StringLiteral <- '\'' [^\']* '\''

Type <- TypeVariations ArrayBounds*
TypeVariations <- TimeType / IntervalType / BitType / RowType / VariantType / MapType / ArrayAngleBracketsType / TupleType / GeometryType / UnionType / NumericType / SetofType / SimpleType
SimpleType <- CharacterSimpleType / QualifiedSimpleType
CharacterSimpleType <- CharacterType TypeModifiers?
QualifiedSimpleType <- QualifiedTypeName TypeModifiers?
CharacterType <- ('CHARACTER' 'VARYING'?) /
                 ('CHAR' 'VARYING'?) /
                 ('NATIONAL' 'CHARACTER' 'VARYING'?) /
                 ('NATIONAL' 'CHAR' 'VARYING'?) /
                 ('NCHAR' 'VARYING'?) /
                 'VARCHAR'

IntervalType <- IntervalInterval / IntervalNumber
IntervalInterval <- IntervalWithSpecifier / IntervalWithoutSpecifier
IntervalWithSpecifier <- IntervalWithRangeSpecifier / IntervalWithSimpleSpecifier
IntervalWithRangeSpecifier <- 'INTERVAL' IntervalToIntervalAsType
IntervalWithSimpleSpecifier <- 'INTERVAL' Interval
IntervalWithoutSpecifier <- 'INTERVAL'

IntervalToIntervalAsType <- (YearKeyword 'TO' MonthKeyword) /
    (DayKeyword 'TO' HourKeyword) /
    (DayKeyword 'TO' MinuteKeyword) /
    (DayKeyword 'TO' SecondKeyword) /
    (HourKeyword 'TO' MinuteKeyword) /
    (HourKeyword 'TO' SecondKeyword) /
    (MinuteKeyword 'TO' SecondKeyword)
IntervalNumber <- 'INTERVAL' Parens(NumberLiteral)

YearKeyword         <- 'YEAR' / 'YEARS'
MonthKeyword        <- 'MONTH' / 'MONTHS'
DayKeyword          <- 'DAY' / 'DAYS'
HourKeyword         <- 'HOUR' / 'HOURS'
MinuteKeyword       <- 'MINUTE' / 'MINUTES'
SecondKeyword       <- 'SECOND' / 'SECONDS'
MillisecondKeyword  <- 'MILLISECOND' / 'MILLISECONDS'
MicrosecondKeyword  <- 'MICROSECOND' / 'MICROSECONDS'
WeekKeyword         <- 'WEEK' / 'WEEKS'
QuarterKeyword      <- 'QUARTER' / 'QUARTERS'
DecadeKeyword       <- 'DECADE' / 'DECADES'
CenturyKeyword      <- 'CENTURY' / 'CENTURIES'
MillenniumKeyword   <- 'MILLENNIUM' / 'MILLENNIA'

Interval <- IntervalToInterval /
    YearKeyword /
    MonthKeyword /
    DayKeyword /
    HourKeyword /
    MinuteKeyword /
    SecondKeyword /
    MillisecondKeyword /
    MicrosecondKeyword /
    WeekKeyword /
    QuarterKeyword /
    DecadeKeyword /
    CenturyKeyword /
    MillenniumKeyword

IntervalToInterval <- YearToMonth /
    DayToHour /
    DayToMinute /
    DayToSecond /
    HourToMinute /
    HourToSecond /
    MinuteToSecond
YearToMonth <- YearKeyword 'TO' MonthKeyword
DayToHour <- DayKeyword 'TO' HourKeyword
DayToMinute <- DayKeyword 'TO' MinuteKeyword
DayToSecond <- DayKeyword 'TO' SecondKeyword
HourToMinute <- HourKeyword 'TO' MinuteKeyword
HourToSecond <- HourKeyword 'TO' SecondKeyword
MinuteToSecond <- MinuteKeyword 'TO' SecondKeyword

BitType <- 'BIT' 'VARYING'? Parens(List(Expression))?
GeometryType <- 'GEOMETRY' Parens(Expression)?
VariantType <- 'VARIANT'

NumericType <- SimpleNumericType / DecimalNumericType
SimpleNumericType <- IntType / IntegerType / SmallintType /
                BigintType / RealType / BooleanType / DoubleType
DecimalNumericType <- FloatType / DecimalType / DecType / NumericModType

IntType <- 'INT'
IntegerType <- 'INTEGER'
SmallintType <- 'SMALLINT'
BigintType <- 'BIGINT'
RealType <- 'REAL'
BooleanType <- 'BOOLEAN'
DoubleType <- ('DOUBLE' 'PRECISION')

FloatType <- 'FLOAT' Parens(NumberLiteral)?
DecimalType <- 'DECIMAL' TypeModifiers?
DecType <- 'DEC' TypeModifiers?
NumericModType <- 'NUMERIC' TypeModifiers?

QualifiedTypeName <- CatalogReservedSchemaTypeName / SchemaReservedTypeName / TypeNameAsQualifiedName
TypeNameAsQualifiedName <- TypeName
CatalogReservedSchemaTypeName <- CatalogQualification ReservedSchemaQualification ReservedTypeName
SchemaReservedTypeName <- SchemaQualification ReservedTypeName
TypeModifiers <- Parens(List(Expression)?)
RowType <- RowOrStruct ColIdTypeList?
SetofType <- 'SETOF' Type
UnionType <- 'UNION' ColIdTypeList
ColIdTypeList <- ColIdParensTypeList / ColIdAngleBracketsTypeList
ColIdParensTypeList <- Parens(List(ColIdType))
ColIdAngleBracketsTypeList <- AngleBrackets(List(ColIdColonType))
MapType <- MapParensListType / MapAngleBracketsListType
MapParensListType <- 'MAP' Parens(List(Type))
MapAngleBracketsListType <- 'MAP' AngleBrackets(List(Type))
ArrayAngleBracketsType <- 'ARRAY' AngleBrackets(Type)
TupleType <- 'TUPLE' Parens(List(Type))
ColIdType <- ColId Type
ColIdColonType <- ColId ':' Type
ArrayBounds <- SquareBracketsArray / ArrayKeyword
ArrayKeyword <- 'ARRAY'
SquareBracketsArray <- '[' Expression? ']'
TimeType <- TimeOrTimestamp TypeModifiers? TimeZone?
TimeOrTimestamp <- TimeTypeId / TimestampTypeId
TimeTypeId <- 'TIME'
TimestampTypeId <- 'TIMESTAMP'
TimeZone <- WithOrWithout 'TIME' 'ZONE'
WithOrWithout <- WithRule / WithoutRule
WithRule <- 'WITH'
WithoutRule <- 'WITHOUT'

RowOrStruct <- 'ROW' / 'STRUCT'

# Spark static/dynamic partition spec, shared by INSERT, ANALYZE and DESCRIBE: PARTITION (col [= value], ...)
PartitionSpec <- 'PARTITION' Parens(List(PartitionSpecEntry))
PartitionSpecEntry <- ColId PartitionSpecValue?
PartitionSpecValue <- '=' Expression

# internal definitions
%whitespace <- [ \t\n\r]*
List(D) <- D (',' D)* ','?
Parens(D) <- '(' D ')'
AngleBrackets(D) <- '<' D CloseAngleBracket
# Closes an angle-bracket type. The tokenizer splits '>'-led operator runs into individual '>'
# tokens (keeping a trailing '>=' glued), and the keyword/operator matchers re-glue adjacent pieces
# for expression operators ('>>', '>>='). Overridden in matcher.cpp to take exactly one '>' token,
# ignoring run adjacency - so nested closers (array<array<int>>) and a trailing operator
# (x::array<int>>y) both resolve.
CloseAngleBracket <- '>'

