CreateViewStmt <- CreateRecursive? 'VIEW' IfNotExists? QualifiedName ViewColumnList? WithSchemaMode? InsertColumnList? WithList? 'AS' SelectStatementInternal
CreateRecursive <- 'RECURSIVE'
ViewColumnList <- Parens(List(ViewColumn))
ViewColumn <- ColId ('COMMENT' StringLiteral)?

WithSchemaMode <- 'WITH' 'SCHEMA' SchemaModeName
SchemaModeName <- 'BINDING' / 'COMPENSATION' / 'EVOLUTION' / ('TYPE' 'EVOLUTION')